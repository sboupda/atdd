#!/usr/bin/env bash
# pre-commit hook — prevent broken state from landing in commits.
#
# Installed via:
#   git config core.hooksPath .git-hooks
# (run once per clone; scripts/install-hooks.sh automates this)
#
# Checks:
#   1. No unresolved git conflict markers in staged content
#   2. .atdd/config.yaml parses as valid YAML (if staged)

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

FAIL=0

# ─── 1. Conflict markers ───────────────────────────────────────────────
# Inspect only the content being committed (staged diff), not the whole file.
# git diff --check exits non-zero when markers are present in staged hunks.
if ! git diff --cached --check; then
  echo "" >&2
  echo "pre-commit: unresolved conflict markers in staged changes." >&2
  echo "            resolve them and re-stage before committing." >&2
  FAIL=1
fi

# ─── 2. YAML validity for .atdd/config.yaml ────────────────────────────
if git diff --cached --name-only | grep -qx ".atdd/config.yaml"; then
  # Validate the staged version (not the working copy), so we test what
  # will actually be committed.
  STAGED_YAML=$(git show ":.atdd/config.yaml" 2>/dev/null || true)
  if [[ -n "$STAGED_YAML" ]]; then
    if ! echo "$STAGED_YAML" | python3 -c "import sys, yaml; yaml.safe_load(sys.stdin)" 2>/tmp/yaml_err; then
      echo "" >&2
      echo "pre-commit: .atdd/config.yaml is invalid YAML." >&2
      cat /tmp/yaml_err >&2
      FAIL=1
    fi
  fi
fi

if [[ $FAIL -ne 0 ]]; then
  echo "" >&2
  echo "commit blocked. override with --no-verify ONLY if you know why." >&2
  exit 1
fi

exit 0
