{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "commons:error:response",
  "title": "CommonsErrorResponse",
  "description": "Structured error response contract for all HTTP endpoints. All error responses MUST conform to this shape for consistent client-side handling.",
  "version": "1.0.0",
  "type": "object",
  "x-artifact-metadata": {
    "domain": "commons",
    "resource": "error",
    "version": "1.0.0",
    "hash": "",
    "producer": "wagon:verify-contracts",
    "consumers": [
      "wagon:implement-code"
    ],
    "dependencies": [],
    "api": {
      "operations": [
        {
          "method": "ANY",
          "path": "/*",
          "description": "Error response shape for any failing endpoint",
          "responses": {
            "4xx": {
              "description": "Client error",
              "schema": "$ref: #"
            },
            "5xx": {
              "description": "Server error",
              "schema": "$ref: #"
            }
          }
        }
      ]
    },
    "traceability": {
      "wagon_ref": "plan/verify_contracts/_verify_contracts.yaml",
      "feature_refs": [
        "feature:verify-contracts:error-response-contract"
      ]
    },
    "governance": {
      "status": "draft"
    }
  },
  "properties": {
    "status_code": {
      "type": "integer",
      "description": "HTTP status code (error range)",
      "minimum": 400,
      "maximum": 599
    },
    "error_code": {
      "type": "string",
      "description": "Enum-based error code in UPPER_SNAKE_CASE",
      "pattern": "^[A-Z][A-Z0-9_]+$"
    },
    "message": {
      "type": "string",
      "description": "Human-readable error message"
    },
    "details": {
      "type": "object",
      "description": "Optional structured context for debugging",
      "additionalProperties": true
    }
  },
  "required": [
    "status_code",
    "error_code",
    "message"
  ],
  "additionalProperties": false
}
