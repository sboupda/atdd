{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "commons:compliance:gate",
  "title": "CommonsComplianceGate",
  "description": "ATDD gate verification output — confirms agent loaded rules correctly",
  "version": "1.0.0",
  "type": "object",
  "x-artifact-metadata": {
    "domain": "commons",
    "resource": "compliance",
    "version": "1.0.0",
    "hash": "",
    "producer": "wagon:govern-lifecycle",
    "consumers": [],
    "dependencies": [],
    "api": {
      "operations": [
        {
          "method": "GET",
          "path": "/cli/gate",
          "description": "Return gate verification as JSON",
          "responses": {
            "200": { "description": "Gate verification data", "schema": "$ref: #" }
          }
        }
      ]
    },
    "traceability": {
      "wagon_ref": "plan/govern_lifecycle/_govern_lifecycle.yaml",
      "feature_refs": ["feature:self-compliance-migration:bootstrap-compliance"]
    },
    "governance": {
      "status": "draft"
    }
  },
  "properties": {
    "files": {
      "type": "object",
      "description": "Agent config files loaded by gate",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "exists": { "type": "boolean" },
          "has_block": { "type": "boolean" },
          "hash": { "type": "string" },
          "hash_full": { "type": "string" }
        },
        "required": ["file", "exists", "has_block", "hash"]
      }
    },
    "constraints": {
      "type": "array",
      "description": "Key ATDD constraints extracted from loaded files",
      "items": { "type": "string" },
      "minItems": 1
    },
    "issue_convention": {
      "type": "string",
      "description": "Full issue convention YAML content"
    },
    "worktree_layout": {
      "type": "string",
      "description": "Worktree layout configuration"
    }
  },
  "required": ["files", "constraints"],
  "additionalProperties": true
}
