#!/bin/sh
# ATDD pre-merge-commit hook — version gate.
# Installed by `atdd init`. Skip with ATDD_SKIP_VERSION_GATE=1.
# Standard bypass: git merge --no-verify

set -e

# --- Version gate ---
if [ "${ATDD_SKIP_VERSION_GATE:-0}" != "1" ]; then
    python3 -c "
try:
    from atdd.version_check import _gate_main
    _gate_main()
except ImportError:
    import sys
    print('ATDD: version gate requires a newer atdd package.', file=sys.stderr)
    print('  Run: pip install --upgrade atdd', file=sys.stderr)
    sys.exit(1)
" 2>&1
    if [ $? -ne 0 ]; then exit 1; fi
fi

exit 0
